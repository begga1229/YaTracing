PORT=5000
NODE_ENV=development
DB_HOST=localhost
DB_PORT=5432
DB_NAME=yatracing
DB_USER=postgres
DB_PASSWORD=password
JWT_SECRET=your-secret-key-change-in-production
CORS_ORIGIN=http://localhost:3000
REDIS_URL=redis://localhost:6379

# Metraj (AI quantity takeoff) - Claude Vision for PDF/image drawings
# https://console.anthropic.com/ adresinden bir API anahtari alin
ANTHROPIC_API_KEY=
# Metraj icin kullanilacak model (varsayilan: claude-opus-4-8)
ANTHROPIC_MODEL=claude-opus-4-8
# Yuklenebilecek maksimum cizim dosyasi boyutu (MB)
MAX_UPLOAD_MB=25