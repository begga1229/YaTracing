# NOT: Mobil uygulama API adresini oncelikle app.json > expo.extra.apiUrl'den okur.
# En saglikli yol app.json icindeki apiUrl'i backend'in calistigi bilgisayarin
# yerel ag IP'si ile guncellemektir (or. http://192.168.1.100:5000/api).
# Bu dosya yalnizca alternatif/gelistirme icindir.
REACT_APP_API_URL=http://192.168.1.100:5000/api
REACT_APP_SOCKET_URL=http://192.168.1.100:5000
